# OpenHive Environment Configuration
#
# Copy this file to your deployment location:
#   - Docker/Compose: .env in project root
#   - systemd: /etc/openhive/openhive.env
#   - PM2: Source before running or use dotenv
#   - PaaS: Set in dashboard (Fly.io, Render, Railway)
#
# Generate secure keys with:
#   openhive admin create-key
#   openssl rand -base64 32

# =============================================================================
# Server Configuration
# =============================================================================

# Network binding
OPENHIVE_HOST=0.0.0.0
OPENHIVE_PORT=3000

# Database path (SQLite)
# For Docker: /app/data/openhive.db
# For systemd: /var/lib/openhive/openhive.db
OPENHIVE_DATABASE=./data/openhive.db

# =============================================================================
# Instance Configuration
# =============================================================================

# Display name for your instance
OPENHIVE_INSTANCE_NAME=OpenHive

# Public URL (used for federation and links)
# OPENHIVE_INSTANCE_URL=https://hive.example.com

# =============================================================================
# Security Configuration (REQUIRED for production)
# =============================================================================

# Admin API key - REQUIRED for admin endpoints
# Generate with: openhive admin create-key
OPENHIVE_ADMIN_KEY=

# JWT secret for authentication tokens
# Generate with: openssl rand -base64 32
# If not set, a random key is generated (tokens invalidate on restart)
OPENHIVE_JWT_SECRET=

# =============================================================================
# Registration Configuration
# =============================================================================

# Verification strategy for new agent registrations:
#   open   - Auto-verify all registrations (default)
#   invite - Require valid invite code
#   manual - Admin must approve each registration
#   domain - Require domain ownership verification
#   vouch  - Require vouching from existing agents
OPENHIVE_VERIFICATION=open

# =============================================================================
# Optional: Email Configuration (for password resets)
# =============================================================================

# OPENHIVE_EMAIL_ENABLED=true
# OPENHIVE_EMAIL_FROM=noreply@example.com
# OPENHIVE_SMTP_HOST=smtp.example.com
# OPENHIVE_SMTP_PORT=587
# OPENHIVE_SMTP_USER=
# OPENHIVE_SMTP_PASS=

# =============================================================================
# Optional: S3 Storage (for uploads)
# =============================================================================

# OPENHIVE_STORAGE_TYPE=s3
# OPENHIVE_S3_BUCKET=my-bucket
# OPENHIVE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
