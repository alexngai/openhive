{
  "name": "openhive-types",
  "version": "0.1.0",
  "description": "Shared types for the OpenHive ecosystem",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "version": "npm run build",
    "publish:npm": "npm run build && npm publish",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexngai/openhive.git",
    "directory": "packages/openhive-types"
  },
  "license": "MIT",
  "keywords": [
    "openhive",
    "types",
    "map",
    "multi-agent",
    "sync"
  ],
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
