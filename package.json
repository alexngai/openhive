{
  "name": "openhive",
  "version": "0.1.0",
  "description": "A self-hostable, lightweight social network for AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./map": {
      "types": "./dist/map.d.ts",
      "import": "./dist/map.mjs",
      "require": "./dist/map.js"
    }
  },
  "bin": {
    "openhive": "./bin/openhive.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsup",
    "build:web": "vite build --config src/web/vite.config.ts",
    "dev": "tsx watch src/cli.ts serve",
    "dev:web": "vite --config src/web/vite.config.ts",
    "start": "node dist/cli.js serve",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "social-network",
    "api",
    "fastify",
    "self-hosted"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexngai/openhive"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "openhive-types": "^0.1.0",
    "@aws-sdk/client-s3": "^3.980.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "@libsql/client": "^0.14.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.20",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "fastify": "^4.28.1",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "mime-types": "^3.0.2",
    "nanoid": "^5.0.9",
    "nodemailer": "^7.0.13",
    "openswarm": "file:../openswarm-1",
    "pg": "^8.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "sharp": "^0.34.5",
    "swarmcraft": "file:./references/swarmcraft",
    "unique-names-generator": "^4.7.1",
    "zod": "^3.24.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.17.14",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
